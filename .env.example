# Google Sheets API Configuration
# Get this from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here

# Google Sheet ID from the URL:
# https://docs.google.com/spreadsheets/d/[THIS_IS_THE_SHEET_ID]/edit
VITE_GOOGLE_SHEET_ID=1zeZf0sqXBCVzYZwe1UuOJXHW-Yai0TGi25sIzENX_68

# Auth Configuration - Multiple Users
# Format: JSON array of user objects
# Each user: {"login": "username", "passwordHash": "sha256_hash", "name": "Display Name"}
# Example for 3 users:
VITE_AUTH_USERS=[{"login":"admin","passwordHash":"8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918","name":"Administrator"},{"login":"manager","passwordHash":"5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8","name":"Manager"},{"login":"viewer","passwordHash":"4fc82b26aecb47d2868c4efbe3581732a3e7cbcc6c2efb32062c08170a05eeb8","name":"Viewer"}]

# Legacy single user configuration (used if VITE_AUTH_USERS is not set)
VITE_AUTH_LOGIN=admin
VITE_AUTH_PASSWORD_HASH=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
# ^^^ This is SHA-256 hash of "admin" - change in production!

# Pagination
VITE_PAGINATION_PAGE_SIZE=20
VITE_PAGINATION_THRESHOLD=200

# Cache TTL in milliseconds (5 minutes = 300000)
VITE_CACHE_TTL=300000
